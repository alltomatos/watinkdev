# Watink Traefik-first deployment
# Required
APP_DOMAIN=app.seudominio.com
API_DOMAIN=api.seudominio.com

# Stack / networks
STACK_NAME=watink
TRAEFIK_NETWORK=traefik-public
INTERNAL_NETWORK=watink-internal
TRAEFIK_CERT_RESOLVER=letsencryptresolver

# Core secrets (CHANGE IN PRODUCTION)
POSTGRES_DB=watink
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_postgres
JWT_SECRET=change_me_jwt_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
WATINK_MASTER_KEY=change_me_master_key

# Optional image overrides
BACKEND_IMAGE=watink/backend:1.3.488
FRONTEND_IMAGE=watink/frontend:0.7.367
ENGINE_IMAGE=watink/engine:1.0.123
POSTGRES_IMAGE=watink/postgres-postgis-pgvector:16-optimized

# Optional replicas
BACKEND_REPLICAS=1
FRONTEND_REPLICAS=1
ENGINE_REPLICAS=1
FLOW_WORKER_REPLICAS=1
POSTGRES_REPLICAS=1
REDIS_REPLICAS=1
RABBITMQ_REPLICAS=1
